{%- comment -%}
  Bundle Builder UI Snippet
  Renders the full bundle builder (tier bar, slots, popup, preview).
  Used by both sections/bundle-builder.liquid (as a section) and main-product.liquid (as a block).

  Required:
    bb_settings - hash with these keys:
      collection (string handle)
      heading
      popup_heading
      banner_text
      footer_text
      show_filters (bool)
      filter_tags (CSV string)
      tier1_count, tier1_discount
      tier2_count, tier2_discount
      tier3_count, tier3_discount
      tier4_count, tier4_discount
    bb_id (optional unique id suffix)
{%- endcomment -%}

{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

{%- assign bb_collection = collections[bb_settings.collection] -%}
{%- assign bb_id = bb_id | default: 'bb' -%}

<bundle-builder
  class="bb"
  data-tiers='[{"count":{{ bb_settings.tier1_count }},"discount":{{ bb_settings.tier1_discount }}},{"count":{{ bb_settings.tier2_count }},"discount":{{ bb_settings.tier2_discount }}},{"count":{{ bb_settings.tier3_count }},"discount":{{ bb_settings.tier3_discount }}},{"count":{{ bb_settings.tier4_count }},"discount":{{ bb_settings.tier4_discount }}}]'
>
  <div class="bb__inner">
    <!-- Tier Progress Bar -->
    <div class="bb-tiers">
      <div class="bb-tiers__track"><div class="bb-tiers__track-fill"></div></div>
      <div class="bb-tier active" data-index="0">
        <span class="bb-tier__discount">{{ bb_settings.tier1_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ bb_settings.tier1_count }} Designs</span>
      </div>
      <div class="bb-tier" data-index="1">
        <span class="bb-tier__discount">{{ bb_settings.tier2_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ bb_settings.tier2_count }}+ Designs</span>
      </div>
      <div class="bb-tier" data-index="2">
        <span class="bb-tier__discount">{{ bb_settings.tier3_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ bb_settings.tier3_count }}+ Designs</span>
      </div>
      <div class="bb-tier" data-index="3">
        <span class="bb-tier__discount">{{ bb_settings.tier4_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ bb_settings.tier4_count }} Designs</span>
      </div>
    </div>

    <h3 class="bb__heading">{{ bb_settings.heading }}</h3>

    <div class="bb-slots-wrapper">
      <div class="bb-slots"></div>
    </div>

    <div class="bb-summary">
      <div class="bb-summary__info"></div>
      <button type="button" class="bb-summary__btn" disabled>SELECT {{ bb_settings.tier1_count }} MORE</button>
    </div>
  </div>

  <!-- POPUP / DRAWER -->
  <div class="bb-popup">
    <div class="bb-popup__overlay"></div>
    <div class="bb-popup__panel">
      <div class="bb-main-view">
        <div class="bb-popup__header">
          <h2 class="bb-popup__title">{{ bb_settings.popup_heading }}</h2>
          <button type="button" class="bb-popup__close" aria-label="Close">&times;</button>
        </div>

        {%- if bb_settings.show_filters -%}
          <div class="bb-popup__filters">
            <span class="bb-popup__filters-label">Shape</span>
            {%- assign filter_tags = bb_settings.filter_tags | split: ',' -%}
            {%- for tag in filter_tags -%}
              {%- assign clean_tag = tag | strip -%}
              <button type="button" class="bb-filter-btn" data-filter="{{ clean_tag }}">{{ clean_tag }}</button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if bb_settings.banner_text != blank -%}
          <div class="bb-popup__banner">{{ bb_settings.banner_text }}</div>
        {%- endif -%}

        <div class="bb-popup__body">
          <div class="bb-popup__grid">
            {%- if bb_collection != blank and bb_collection.products.size > 0 -%}
              {%- for bb_product in bb_collection.products -%}
                {%- capture image_array -%}
                  [{%- for image in bb_product.images -%}"{{ image | image_url: width: 800 }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}{%- if bb_product.images.size == 0 -%}"{{ bb_product.featured_image | image_url: width: 800 }}"{%- endif -%}]
                {%- endcapture -%}
                <div
                  class="bb-product-card"
                  data-id="{{ bb_product.id }}"
                  data-handle="{{ bb_product.handle }}"
                  data-title="{{ bb_product.title | escape }}"
                  data-shape="{{ bb_product.type | default: 'Press-On' | escape }}"
                  data-tags="{{ bb_product.tags | join: ',' | downcase }}"
                  data-images='{{ image_array | strip }}'
                >
                  <img
                    class="bb-product-card__img"
                    src="{{ bb_product.featured_image | image_url: width: 400 }}"
                    alt="{{ bb_product.title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                  <p class="bb-product-card__shape">{{ bb_product.type | default: 'Press-On' }}</p>
                  <p class="bb-product-card__name">{{ bb_product.title }}</p>
                  <button type="button" class="bb-product-card__preview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                    Preview
                  </button>
                </div>
              {%- endfor -%}
            {%- else -%}
              <p style="grid-column: 1/-1; text-align: center; color: #999; padding: 40px 0;">No designs found. Set a collection in the section settings.</p>
            {%- endif -%}
          </div>
        </div>

        {%- if bb_settings.footer_text != blank -%}
          <div class="bb-popup__footer">{{ bb_settings.footer_text }}</div>
        {%- endif -%}
      </div>

      <div class="bb-preview">
        <div class="bb-popup__header">
          <button type="button" class="bb-popup__back" aria-label="Back">&larr;</button>
          <h2 class="bb-popup__title">{{ bb_settings.popup_heading }}</h2>
          <button type="button" class="bb-popup__close" aria-label="Close">&times;</button>
        </div>
        <div class="bb-popup__body">
          <div class="bb-preview__carousel">
            <div class="bb-preview__slides"></div>
            <div class="bb-preview__nav">
              <button type="button" class="bb-preview__arrow bb-preview__arrow--prev" aria-label="Previous">&larr;</button>
              <div class="bb-preview__dots"></div>
              <button type="button" class="bb-preview__arrow bb-preview__arrow--next" aria-label="Next">&rarr;</button>
            </div>
          </div>
          <h3 class="bb-preview__name"></h3>
          <p class="bb-preview__shape"></p>
          <button type="button" class="bb-preview__select">+ Select</button>
          <button type="button" class="bb-preview__back-link">Back To All Designs</button>
        </div>
      </div>
    </div>
  </div>
</bundle-builder>

<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>
