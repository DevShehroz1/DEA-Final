{{ 'hero-dea.css' | asset_url | stylesheet_tag }}

<div id="hero-dea-{{ section.id }}" class="hero-dea" style="
  --hero-bg: {{ section.settings.bg_color }};
  --hero-accent: {{ section.settings.accent_color }};
  --hero-text: {{ section.settings.text_color }};
  --hero-btn-bg: {{ section.settings.button_bg }};
  --hero-btn-text: {{ section.settings.button_text_color }};
  --section-pt: {{ section.settings.padding_top }}px;
  --section-pb: {{ section.settings.padding_bottom }}px;
">
  <div class="hero-dea__container">
    {%- comment -%} LEFT: Text Content {%- endcomment -%}
    <div class="hero-dea__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-dea__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading_line1 != blank or section.settings.heading_line2 != blank -%}
        <h1 class="hero-dea__heading">
          {%- if section.settings.heading_line1 != blank -%}
            <span class="hero-dea__heading-line1">{{ section.settings.heading_line1 }}</span>
          {%- endif -%}
          {%- if section.settings.heading_line2 != blank -%}
            <span class="hero-dea__heading-line2">{{ section.settings.heading_line2 }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero-dea__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="hero-dea__cta"
        >
          {{ section.settings.button_label }}
          <span class="hero-dea__cta-arrow">&rarr;</span>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: Image {%- endcomment -%}
    <div class="hero-dea__media">
      <div class="hero-dea__arch">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.image | image_url: width: 500 }} 500w,
              {{ section.settings.image | image_url: width: 700 }} 700w,
              {{ section.settings.image | image_url: width: 900 }} 900w
            "
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | default: section.settings.heading_line1 }}"
            loading="eager"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            class="hero-dea__image"
          >
        {%- else -%}
          <div class="hero-dea__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-dea__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero DEA",
  "tag": "section",
  "class": "section-hero-dea",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Press-On Perfection"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Salon Nails."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2 (accent color)",
      "default": "Zero Appointment."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium press-on nails that last up to 2 weeks. Apply in minutes, look like you spent hours."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F5F0EB"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (heading line 2)",
      "default": "#8B6459"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#F5F0EB"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero DEA"
    }
  ]
}
{% endschema %}
