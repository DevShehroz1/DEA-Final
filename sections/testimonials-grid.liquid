<style>
  .testimonials-grid {
    padding-top: var(--section-pt, 60px);
    padding-bottom: var(--section-pb, 60px);
  }
  .testimonials-grid .testimonials-grid__inner {
    width: 100%;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .testimonials-grid .testimonials-grid__heading {
    font-family: 'Clash Display', var(--heading-font), sans-serif;
    font-weight: 500;
    font-style: normal;
    font-size: 46px;
    line-height: 50px;
    letter-spacing: -1.12px;
    text-align: center;
    text-transform: uppercase;
    margin: 0 0 50px;
    padding: 0;
    color: var(--color-foreground, #000);
  }
  .testimonials-grid .testimonials-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .testimonials-grid .testimonials-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 0 12px;
  }
  .testimonials-grid .testimonials-grid__stars {
    display: inline-flex;
    gap: 6px;
    margin: 0 0 18px;
    color: #b8a0d4;
    font-size: 14px;
    line-height: 1;
  }
  .testimonials-grid .testimonials-grid__stars svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    display: block;
  }
  .testimonials-grid .testimonials-grid__text {
    font-family: 'Aeonik', var(--body-font), sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 14px;
    line-height: 18px;
    letter-spacing: 0;
    text-align: center;
    color: var(--color-foreground, #000);
    margin: 0 0 22px;
    padding: 0;
    max-width: 280px;
  }
  .testimonials-grid .testimonials-grid__name {
    font-family: 'Clash Display', var(--heading-font), sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 20px;
    line-height: 22px;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
    color: var(--color-foreground, #000);
    margin: 0;
    padding: 0;
  }
  @media (max-width: 991.98px) {
    .testimonials-grid .testimonials-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 20px;
    }
  }
  @media (max-width: 575.98px) {
    .testimonials-grid .testimonials-grid__heading {
      font-size: 30px;
      line-height: 34px;
      letter-spacing: -0.5px;
      margin-bottom: 32px;
    }
    .testimonials-grid .testimonials-grid__items {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
{%- liquid
  assign sec_st = section.settings
-%}
<div
  id="testimonials-grid-{{ section.id }}"
  class="testimonials-grid color-{{ sec_st.color_scheme }} gradient"
  style="--section-pt: {{ sec_st.padding_top }}px; --section-pb: {{ sec_st.padding_bottom }}px;"
>
  <div class="testimonials-grid__inner">
    {%- if sec_st.heading != blank -%}
      <h2 class="testimonials-grid__heading">{{ sec_st.heading }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="testimonials-grid__items">
        {%- for block in section.blocks -%}
          {%- liquid
            assign b = block.settings
            assign rating = b.rating | default: 5
          -%}
          <div class="testimonials-grid__item" {{ block.shopify_attributes }}>
            <div class="testimonials-grid__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0l2.09 5.36L16 6.12l-4.46 3.86L12.98 16 8 13.1 3.02 16l1.44-6.02L0 6.12l5.91-.76L8 0z"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 16 16" aria-hidden="true" style="opacity:0.25"><path d="M8 0l2.09 5.36L16 6.12l-4.46 3.86L12.98 16 8 13.1 3.02 16l1.44-6.02L0 6.12l5.91-.76L8 0z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- if b.text != blank -%}
              <div class="testimonials-grid__text">{{ b.text }}</div>
            {%- endif -%}
            {%- if b.name != blank -%}
              <div class="testimonials-grid__name">{{ b.name }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Testimonials Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRIED, TESTED AND TRUSTED"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 12,
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating (stars)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "I never thought about fragrance actually doing something. Now I can't go back."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "ADITI, MUMBAI"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Grid",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I never thought about fragrance actually doing something. Now I can't go back.",
            "name": "ADITI, MUMBAI"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "It's so light you forget you're wearing it. Then you realise you've felt fresh all day.",
            "name": "ROHAN, BENGALURU"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Came for the refill idea. The scent made me stay.",
            "name": "NEHA, DELHI"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "First deodorant that actually lasts through Mumbai humidity.",
            "name": "VIMAL, MUMBAI"
          }
        }
      ]
    }
  ]
}
{% endschema %}
