{%- assign bb_settings = section.settings -%}
{% render 'bundle-builder-ui', bb_settings: bb_settings, bb_id: section.id %}

{% schema %}
{
  "name": "Bundle Builder",
  "tag": "section",
  "class": "section-bundle-builder",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Designs collection"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Choose your designs:"
    },
    {
      "type": "text",
      "id": "popup_heading",
      "label": "Popup heading",
      "default": "Choose Your Designs"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Popup banner text",
      "default": "Find your length and your style"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Popup footer text",
      "default": "Free trial with the money-back guarantee"
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show shape filters",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_tags",
      "label": "Filter tag names (comma separated)",
      "default": "Almond,Round,Square,Coffin"
    },
    {
      "type": "header",
      "content": "Tier 1"
    },
    {
      "type": "number",
      "id": "tier1_count",
      "label": "Number of designs",
      "default": 3
    },
    {
      "type": "number",
      "id": "tier1_discount",
      "label": "Discount %",
      "default": 15
    },
    {
      "type": "header",
      "content": "Tier 2"
    },
    {
      "type": "number",
      "id": "tier2_count",
      "label": "Number of designs",
      "default": 4
    },
    {
      "type": "number",
      "id": "tier2_discount",
      "label": "Discount %",
      "default": 21
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "number",
      "id": "tier3_count",
      "label": "Number of designs",
      "default": 6
    },
    {
      "type": "number",
      "id": "tier3_discount",
      "label": "Discount %",
      "default": 30
    },
    {
      "type": "header",
      "content": "Tier 4"
    },
    {
      "type": "number",
      "id": "tier4_count",
      "label": "Number of designs",
      "default": 7
    },
    {
      "type": "number",
      "id": "tier4_discount",
      "label": "Discount %",
      "default": 38
    }
  ],
  "presets": [
    {
      "name": "Bundle Builder"
    }
  ]
}
{% endschema %}
