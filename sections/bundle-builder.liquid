{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

{%- assign bb_collection = collections[section.settings.collection] -%}

<bundle-builder
  class="bb"
  data-tiers='[{"count":{{ section.settings.tier1_count }},"discount":{{ section.settings.tier1_discount }}},{"count":{{ section.settings.tier2_count }},"discount":{{ section.settings.tier2_discount }}},{"count":{{ section.settings.tier3_count }},"discount":{{ section.settings.tier3_discount }}},{"count":{{ section.settings.tier4_count }},"discount":{{ section.settings.tier4_discount }}}]'
>
  <div class="bb__inner">
    <!-- Tier Progress Bar -->
    <div class="bb-tiers">
      <div class="bb-tiers__track"><div class="bb-tiers__track-fill"></div></div>
      <div class="bb-tier active" data-index="0">
        <span class="bb-tier__discount">{{ section.settings.tier1_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ section.settings.tier1_count }} Designs</span>
      </div>
      <div class="bb-tier" data-index="1">
        <span class="bb-tier__discount">{{ section.settings.tier2_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ section.settings.tier2_count }}+ Designs</span>
      </div>
      <div class="bb-tier" data-index="2">
        <span class="bb-tier__discount">{{ section.settings.tier3_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ section.settings.tier3_count }}+ Designs</span>
      </div>
      <div class="bb-tier" data-index="3">
        <span class="bb-tier__discount">{{ section.settings.tier4_discount }}% OFF</span>
        <span class="bb-tier__circle"></span>
        <span class="bb-tier__label">{{ section.settings.tier4_count }} Designs</span>
      </div>
    </div>

    <!-- Slots Heading -->
    <h3 class="bb__heading">{{ section.settings.heading }}</h3>

    <!-- Slots Grid (rendered by JS) -->
    <div class="bb-slots-wrapper">
      <div class="bb-slots"></div>
    </div>

    <!-- Summary -->
    <div class="bb-summary">
      <div class="bb-summary__info"></div>
      <button type="button" class="bb-summary__btn" disabled>SELECT {{ section.settings.tier1_count }} MORE</button>
    </div>
  </div>

  <!-- =================== POPUP / DRAWER =================== -->
  <div class="bb-popup">
    <div class="bb-popup__overlay"></div>
    <div class="bb-popup__panel">
      <!-- MAIN VIEW: Product Grid -->
      <div class="bb-main-view">
        <div class="bb-popup__header">
          <h2 class="bb-popup__title">{{ section.settings.popup_heading }}</h2>
          <button type="button" class="bb-popup__close" aria-label="Close">&times;</button>
        </div>

        {%- if section.settings.show_filters -%}
          <div class="bb-popup__filters">
            <span class="bb-popup__filters-label">Shape</span>
            {%- assign filter_tags = section.settings.filter_tags | split: ',' -%}
            {%- for tag in filter_tags -%}
              {%- assign clean_tag = tag | strip -%}
              <button type="button" class="bb-filter-btn" data-filter="{{ clean_tag }}">{{ clean_tag }}</button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.banner_text != blank -%}
          <div class="bb-popup__banner">{{ section.settings.banner_text }}</div>
        {%- endif -%}

        <div class="bb-popup__body">
          <div class="bb-popup__grid">
            {%- if bb_collection != blank and bb_collection.products.size > 0 -%}
              {%- for product in bb_collection.products -%}
                {%- capture image_array -%}
                  [{%- for image in product.images -%}"{{ image | image_url: width: 800 }}"{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}{%- if product.images.size == 0 -%}"{{ product.featured_image | image_url: width: 800 }}"{%- endif -%}]
                {%- endcapture -%}
                <div
                  class="bb-product-card"
                  data-id="{{ product.id }}"
                  data-handle="{{ product.handle }}"
                  data-title="{{ product.title | escape }}"
                  data-shape="{{ product.metafields.custom.shape | default: product.type | escape }}"
                  data-tags="{{ product.tags | join: ',' | downcase }}"
                  data-images='{{ image_array | strip | escape }}'
                >
                  <img
                    class="bb-product-card__img"
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                  <p class="bb-product-card__shape">{{ product.metafields.custom.shape | default: product.type | default: 'Press-On' }}</p>
                  <p class="bb-product-card__name">{{ product.title }}</p>
                  <button type="button" class="bb-product-card__preview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                    Preview
                  </button>
                </div>
              {%- endfor -%}
            {%- else -%}
              <p style="grid-column: 1/-1; text-align: center; color: #999; padding: 40px 0;">No designs found. Set a collection in the section settings.</p>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.footer_text != blank -%}
          <div class="bb-popup__footer">{{ section.settings.footer_text }}</div>
        {%- endif -%}
      </div>

      <!-- PREVIEW VIEW: Single Product Detail -->
      <div class="bb-preview">
        <div class="bb-popup__header">
          <button type="button" class="bb-popup__back" aria-label="Back">&larr;</button>
          <h2 class="bb-popup__title">{{ section.settings.popup_heading }}</h2>
          <button type="button" class="bb-popup__close" aria-label="Close">&times;</button>
        </div>
        <div class="bb-popup__body">
          <div class="bb-preview__carousel">
            <div class="bb-preview__slides"></div>
            <div class="bb-preview__nav">
              <button type="button" class="bb-preview__arrow bb-preview__arrow--prev" aria-label="Previous">&larr;</button>
              <div class="bb-preview__dots"></div>
              <button type="button" class="bb-preview__arrow bb-preview__arrow--next" aria-label="Next">&rarr;</button>
            </div>
          </div>
          <h3 class="bb-preview__name"></h3>
          <p class="bb-preview__shape"></p>
          <button type="button" class="bb-preview__select">+ Select</button>
          <button type="button" class="bb-preview__back-link">Back To All Designs</button>
        </div>
      </div>
    </div>
  </div>
</bundle-builder>

<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle Builder",
  "tag": "section",
  "class": "section-bundle-builder",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Designs collection"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Choose your designs:"
    },
    {
      "type": "text",
      "id": "popup_heading",
      "label": "Popup heading",
      "default": "Choose Your Designs"
    },
    {
      "type": "text",
      "id": "banner_text",
      "label": "Popup banner text",
      "default": "Find your length and your style"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Popup footer text",
      "default": "Free trial with the money-back guarantee"
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show shape filters",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_tags",
      "label": "Filter tag names (comma separated)",
      "default": "Almond,Round,Square,Coffin"
    },
    {
      "type": "header",
      "content": "Tier 1"
    },
    {
      "type": "number",
      "id": "tier1_count",
      "label": "Number of designs",
      "default": 3
    },
    {
      "type": "number",
      "id": "tier1_discount",
      "label": "Discount %",
      "default": 15
    },
    {
      "type": "header",
      "content": "Tier 2"
    },
    {
      "type": "number",
      "id": "tier2_count",
      "label": "Number of designs",
      "default": 4
    },
    {
      "type": "number",
      "id": "tier2_discount",
      "label": "Discount %",
      "default": 21
    },
    {
      "type": "header",
      "content": "Tier 3"
    },
    {
      "type": "number",
      "id": "tier3_count",
      "label": "Number of designs",
      "default": 6
    },
    {
      "type": "number",
      "id": "tier3_discount",
      "label": "Discount %",
      "default": 30
    },
    {
      "type": "header",
      "content": "Tier 4"
    },
    {
      "type": "number",
      "id": "tier4_count",
      "label": "Number of designs",
      "default": 8
    },
    {
      "type": "number",
      "id": "tier4_discount",
      "label": "Discount %",
      "default": 38
    }
  ],
  "presets": [
    {
      "name": "Bundle Builder"
    }
  ]
}
{% endschema %}
